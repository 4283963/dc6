{
  "name": "stream-topology-workbench",
  "version": "1.0.0",
  "description": "工业级流媒体服务器本地配置和拓扑管控工作台",
  "main": "electron/main.js",
  "author": "Stream Team",
  "license": "MIT",
  "scripts": {
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env NODE_ENV=development electron .",
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "build:rust": "cd native && npm run build",
    "build:renderer": "vite build",
    "build": "npm run build:rust && npm run build:renderer",
    "start": "electron .",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "d3-force": "^3.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.stream.topology",
    "productName": "StreamTopologyWorkbench",
    "files": [
      "electron/**/*",
      "dist/**/*",
      "native/**/*"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": "nsis"
    }
  }
}
